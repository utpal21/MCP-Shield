# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcp_shield

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...
API_KEY_SALT=change_me_32_char_random_string

# Rate limits (per plan, per minute)
RATE_LIMIT_FREE=60
RATE_LIMIT_PRO=600

# Security scan
SCAN_BLOCKLIST_SEED=malware.com,phishing.org  # comma-separated, loaded into Redis on boot

# MCPize marketplace
MCPIZE_WEBHOOK_SECRET=whsec_...